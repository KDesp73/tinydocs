#!/usr/bin/env bash

set -euo pipefail

function run() {
    echo "[RUN] $*"
    "$@"
}

COMMAND="${1:-}"
SYSTEM_DIR="/usr/local/share/zsh/site-functions"
OUTPUT_DIR="./docs/autocomplete"

USAGE_FILES=(
    "pie-cli.usage"
)

function ensure_tools() {
    if ! command -v cargo >/dev/null 2>&1; then
        echo "Rust toolchain not found. Install with: brew install rust"
        exit 1
    fi

    if ! command -v complgen >/dev/null 2>&1; then
        run cargo install --git https://github.com/adaszko/complgen --tag v0.5.0 complgen
    fi
}

function derive_output_file() {
    local usage="$1"

    if [[ -z "$usage" || ! -f "$usage" ]]; then
        echo "Usage file missing or invalid: $usage" >&2
        exit 1
    fi

    mkdir -p "$OUTPUT_DIR"

    local base
    base="$(basename "$usage" .usage)"
    echo "$OUTPUT_DIR/_$base"
}

function generate_one() {
    local usage="$1"
    local output_file

    output_file="$(derive_output_file "$usage")"

    ensure_tools
    run complgen --zsh "$output_file" "$usage"
    echo "Generated: $output_file"
}

function generate_all() {
    for usage in "${USAGE_FILES[@]}"; do
        generate_one "$OUTPUT_DIR/$usage"
    done
}

function install_autocomplete() {
    if [ ! -d "$SYSTEM_DIR" ]; then
        run sudo mkdir -p "$SYSTEM_DIR"
    fi

    for file in "$OUTPUT_DIR"/_*; do
        [ -f "$file" ] || continue

        if [ -w "$SYSTEM_DIR" ]; then
            run cp "$file" "$SYSTEM_DIR/"
        else
            run sudo cp "$file" "$SYSTEM_DIR/"
        fi
    done

    echo "Done. Restart your shell"
}

case "$COMMAND" in
    generate)
        generate_all
        ;;
    install)
        install_autocomplete
        ;;
    all)
        generate_all
        install_autocomplete
        ;;
    *)
        echo "Usage: $0 {generate|install|all}"
        exit 1
        ;;
esac
