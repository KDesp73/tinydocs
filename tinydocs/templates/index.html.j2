<!DOCTYPE html>
<html lang="en" x-data="{ darkMode: localStorage.getItem('theme') === 'dark' }" :class="{ 'dark': darkMode }">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ name }} Documentation</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script>
        tailwind.config = { 
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        brand: {
                            50: '#f5f7ff',
                            100: '#ebf0fe',
                            500: '#6366f1',
                            600: '#4f46e5',
                            900: '#312e81',
                        }
                    }
                }
            }
        }
    </script>
    <style>
        [x-cloak] { display: none !important; }
        /* Smooth transition for theme switching */
        body { transition: background-color 0.3s ease, color 0.3s ease; }
        .highlight { @apply bg-indigo-100 dark:bg-indigo-900/50 text-indigo-700 dark:text-indigo-300 rounded px-1 ring-1 ring-indigo-200 dark:ring-indigo-800; }
        pre { @apply overflow-x-auto p-4 rounded-xl bg-slate-900 text-slate-100 font-mono text-sm border border-slate-800 shadow-inner my-4; }
    </style>
</head>

<body class="bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-slate-100 font-sans"
      x-data="{ 
        search: '',
        toggleTheme() {
            this.darkMode = !this.darkMode;
            localStorage.setItem('theme', this.darkMode ? 'dark' : 'light');
        },
        match(text) {
            if (!this.search) return true;
            return String(text).toLowerCase().includes(this.search.toLowerCase());
        },
        shouldShowModule(file, name, childrenArray) {
            if (!this.search) return true;
            if (this.match(file) || this.match(name)) return true;
            return childrenArray.some(childName => this.match(childName));
        }
      }">

<header class="bg-white/80 dark:bg-slate-900/80 backdrop-blur-md border-b border-slate-200 dark:border-slate-800 sticky top-0 z-50 shadow-sm">
    <div class="max-w-7xl mx-auto px-6 py-4 flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div class="flex items-center gap-3">
            <div>
                <h1 class="text-xl font-black text-slate-800 dark:text-white tracking-tight">{{ name }}</h1>
                <p class="text-[9px] text-indigo-500 dark:text-indigo-400 font-bold uppercase tracking-[0.3em]">API Documentation</p>
            </div>
        </div>

        <div class="flex items-center gap-4 w-full md:w-auto">
            <div class="relative w-full md:w-80 group">
                <input type="text" x-model="search" placeholder="Quick search..."
                       class="w-full pl-10 pr-4 py-2 bg-slate-100 dark:bg-slate-800 border border-transparent focus:border-indigo-500 dark:focus:border-indigo-400 rounded-xl focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all text-sm">
                <svg class="w-4 h-4 text-slate-400 absolute left-3.5 top-2.5 group-focus-within:text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
            </div>
            <button @click="toggleTheme()" class="p-2.5 rounded-xl bg-slate-100 dark:bg-slate-800 hover:bg-indigo-50 dark:hover:bg-slate-700 text-slate-500 dark:text-slate-400 transition-colors">
                <span x-show="!darkMode" class="text-lg">🌙</span><span x-show="darkMode" class="text-lg">☀️</span>
            </button>
        </div>
    </div>
</header>

<main class="max-w-7xl mx-auto px-6 py-12">
    <div class="space-y-24">
        {% for item in files %}
        {% set module_name = item.docs.args[0] if (item.docs and item.docs.args) else "Unknown" %}
        
        {% set searchable_names = [] %}
        {% if item.docs and item.docs.children %}
            {% for child in item.docs.children %}
                {% if child.args and child.args[0] %}{% set _ = searchable_names.append(child.args[0]) %}{% endif %}
            {% endfor %}
        {% endif %}

        <section x-show="shouldShowModule('{{ item.file }}', '{{ module_name }}', {{ searchable_names | tojson }})" x-cloak class="relative">
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-10 group">
                <div class="space-y-1">
                    <div class="flex items-center gap-2">
                        <span class="h-px w-8 bg-indigo-500"></span>
                        <span class="text-[10px] font-bold text-indigo-500 uppercase tracking-widest">Module Package</span>
                    </div>
                    <h2 class="text-5xl font-extrabold tracking-tighter text-slate-900 dark:text-white" :class="match('{{ module_name }}') && 'highlight'">
                        {{ module_name }}
                    </h2>
                </div>
                <div class="flex flex-col items-end">
                    <span class="px-3 py-1 bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 rounded-full text-xs font-mono border border-slate-200 dark:border-slate-700" :class="match('{{ item.file }}') && 'highlight'">
                        {{ item.file }}
                    </span>
                </div>
            </div>

            <div class="grid grid-cols-1 gap-10 relative">
                <div class="absolute left-0 top-0 bottom-0 w-px bg-gradient-to-b from-indigo-500 via-slate-200 dark:via-slate-800 to-transparent ml-4 hidden md:block"></div>

                {% if item.docs and item.docs.children %}
                    {% for child in item.docs.children %}
                    <div class="relative pl-0 md:pl-12 group" x-show="match('{{ child.args[0] }}') || match('{{ module_name }}') || match('{{ item.file }}')">
                        <div class="absolute left-[-5px] top-4 w-2.5 h-2.5 rounded-full bg-white dark:bg-slate-950 border-2 border-indigo-500 hidden md:block group-hover:scale-125 transition-transform"></div>

                        <div class="bg-white dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800 p-6 rounded-2xl shadow-sm hover:shadow-md transition-shadow">
                            <div class="flex flex-wrap items-center gap-3 mb-6">
                                <span class="text-[9px] font-black px-2 py-1 rounded-md uppercase tracking-wider
                                    {% if child.type == 'class' %} bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400
                                    {% elif child.type == 'function' %} bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-400
                                    {% elif child.type == 'type' %} bg-slate-100 text-slate-700 dark:bg-slate-800 dark:text-slate-300
                                    {% else %} bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400 {% endif %}">
                                    {{ child.marker }}
                                </span>
                                
                                <h3 class="text-2xl font-bold text-slate-800 dark:text-slate-100 tracking-tight" :class="match('{{ child.args[0] }}') && 'highlight'">
                                    {{ child.args[0] }}
                                </h3>
                                
                                <span class="text-[10px] font-mono text-slate-400 ml-auto">Line {{ child.line }}</span>
                            </div>

                            <div class="space-y-4">
                                {% for meta in child.children %}
                                    {% if meta.type == 'description' %}
                                        <p class="text-slate-600 dark:text-slate-400 leading-relaxed text-base">{{ meta.args[0] }}</p>
                                    
                                    {% elif meta.type == 'example' %}
                                        <div class="space-y-2">
                                            <span class="text-[10px] font-bold text-indigo-500 uppercase tracking-widest">{{ meta.marker }}</span>
                                            <pre><code>{{ meta.args[0] }}</code></pre>
                                        </div>

                                    {% elif meta.type == 'parameter' %}
                                        <div class="flex items-center gap-3 p-2 rounded-lg bg-slate-50 dark:bg-slate-800/40 border border-slate-100 dark:border-slate-800">
                                            <span class="text-[9px] font-black uppercase text-pink-500 w-8 shrink-0">{{ meta.marker }}</span>
                                            <code class="text-pink-600 dark:text-pink-400 font-bold text-sm">{{ meta.args[0] }}</code>
                                            <span class="text-slate-400 text-xs">—</span>
                                            <span class="text-slate-500 dark:text-slate-400 italic text-xs">{{ meta.args[1] }}</span>
                                        </div>

                                    {% elif meta.type == 'return' %}
                                        <div class="flex items-center gap-5 mt-4 pt-4 border-t border-slate-100 dark:border-slate-800">
                                            <span class="text-[9px] font-black uppercase text-emerald-500 w-8 shrink-0">{{ meta.marker }}</span>
                                            <code class="text-emerald-600 dark:text-emerald-400 font-bold text-sm">{{ meta.args[0] }}</code>
                                        </div>

                                    {% elif meta.type in ['author', 'license'] %}
                                        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-[10px] text-slate-500">
                                            <span class="font-bold uppercase opacity-60">{{ meta.marker }}:</span>
                                            <span class="font-medium">{{ meta.args[0] }}</span>
                                        </div>

                                    {% elif meta.type == 'any' %}
                                        <div class="p-4 border-l-2 border-indigo-200 dark:border-indigo-800 bg-slate-50/50 dark:bg-slate-800/20 italic text-slate-500 text-sm">
                                            {{ meta.args[0] }}
                                        </div>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                    {% endfor %}
                {% endif %}
            </div>
        </section>
        {% endfor %}
    </div>

    <div x-show="search && !$root.querySelectorAll('section:not([style*=\'display: none\'])').length" class="py-32 text-center" x-cloak>
        <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-slate-100 dark:bg-slate-800 mb-6 text-slate-400">
            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        </div>
        <h3 class="text-xl font-bold text-slate-800 dark:text-white">No matches found</h3>
        <p class="text-slate-500 mt-2">We couldn't find anything matching "<span x-text="search" class="text-indigo-500 font-mono"></span>"</p>
        <button @click="search = ''" class="mt-6 px-6 py-2 bg-indigo-500 hover:bg-indigo-600 text-white rounded-xl text-sm font-bold transition-transform active:scale-95 shadow-lg shadow-indigo-500/25">
            Clear Search
        </button>
    </div>
</main>

<footer class="max-w-7xl mx-auto px-6 py-12 border-t border-slate-200 dark:border-slate-800 text-center">
    <p class="text-slate-400 text-xs font-medium">Generated with {{ name }} • 2026</p>
</footer>

</body>
</html>
